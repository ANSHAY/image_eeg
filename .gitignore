# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
weights/

# Virtual env (user-provisioned, not tracked)
.venv/
venv/
env/

# Data + generated artifacts (keep .gitkeep, ignore everything else)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
checkpoints/*
!checkpoints/.gitkeep
runs/*
!runs/.gitkeep
results/*
!results/.gitkeep
# Sanity-check artifacts are small JSON; keep them tracked so the
# Phase-3 plumbing-pass evidence is visible in git history.
!results/sanity/
!results/sanity/**
# Synthetic LOSO summary — JSON only; never the binary checkpoints
# or TensorBoard event files.
!results/loso_synthetic/
!results/loso_synthetic/**
results/loso_synthetic/**/*.ckpt
results/loso_synthetic/**/tensorboard/
results/loso_synthetic/**/pip_freeze.txt
# Phase 5 benchmark JSON.
!results/phase5_bench.json
# Phase 6 end-to-end smoke summary.
!results/phase6_e2e/
!results/phase6_e2e/**
logs/*
!logs/.gitkeep

# Media (demo recordings)
*.mp4
*.mov
*.webm

# Editors / OS
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# Notebook scratch
.ipynb_checkpoints/

# Local config overrides (kept out of VCS; canonical config.yaml is tracked)
config.local.yaml
*.env
.env
